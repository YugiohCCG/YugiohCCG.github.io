{
  "dependencies": {
    "clsx": "^2.1.1",
    "fuse.js": "^7.1.0",
    "query-string": "^9.2.2",
    "react-router-dom": "^7.8.0",
    "react-window": "^1.8.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^24.5.0",
    "@types/query-string": "^6.2.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^9.1.2",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "source-map": "^0.7.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.1"
  },
  "scripts": {
    "predev": "node scripts/sync-public-cards.cjs",
    "dev": "vite",
    "prebuild": "node scripts/sync-public-cards.cjs",
    "build": "tsc --noEmit && vite build",
    "postbuild": "node -e \"require('fs').copyFileSync('dist/index.html','dist/404.html')\"",
    "preview": "vite preview",
    "sync:public-cards": "node scripts/sync-public-cards.cjs",
    "verify:public-cards": "node scripts/sync-public-cards.cjs --check",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "label:tcg": "node scripts/label-tcg-cards.js",
    "sync:omega:banlist": "node scripts/sync-omega-ccg-banlist.mjs",
    "sync:ygo:draft": "node scripts/sync-ygo-draft-pool.mjs",
    "release:omega": "python scripts/release_omega_assets.py",
    "release:omega:with-omega-install": "python scripts/release_omega_assets.py --use-omega-install",
    "release:omega:publish": "python scripts/release_omega_assets.py --recompile-installer --push",
    "release:omega:stage": "python scripts/release_omega_assets.py --push --commit-message \"Update Omega CCG add-on assets (installer recompile pending)\"",
    "release:omega:installer": "python scripts/release_omega_assets.py --skip-db --skip-images --recompile-installer --push --commit-message \"Recompile Omega CCG installer EXE\"",
    "test:omega": "python scripts/release_omega_assets.py --use-omega-install --export-only --overwrite",
    "release:omega:db-only": "python scripts/release_omega_assets.py --skip-images",
    "release:omega:images-only": "python scripts/release_omega_assets.py --skip-db",
    "package:omega:scripts": "python scripts/package_omega_ccg_scripts.py",
    "verify:omega:scripts": "python scripts/package_omega_ccg_scripts.py --check",
    "verify:omega": "python scripts/verify_omega_release.py"
  },
  "engines": {
    "node": ">=18.18"
  }
}
